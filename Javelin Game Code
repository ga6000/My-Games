<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Javelin Battle</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --bg-dark: #0f380f;
            --bg-medium: #306230;
            --platform-light: #8bac0f;
            --accent-bright: #9bbc0f;
            --white: #ffffff;
        }
        body {
            font-family: 'Press Start 2P', cursive;
            background-color: #000000; /* Updated for black webpage */
            color: var(--accent-bright);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            overflow: hidden;
        }
        canvas {
            background-color: var(--bg-medium);
            border-radius: 0.5rem;
            border: 4px solid var(--accent-bright); /* Updated for visual perimeter */
            display: block;
            max-width: 100%;
        }
        #game-container {
            width: 100%;
            max-width: 1000px;
            aspect-ratio: 16 / 9;
            position: relative;
        }
        #controls-info {
            display: flex;
            justify-content: space-between;
            width: 100%;
            max-width: 1000px;
            padding: 1rem;
            font-size: 0.8rem;
        }
        .player-controls {
            background-color: var(--bg-medium);
            padding: 0.75rem;
            border-radius: 0.5rem;
            border: 2px solid var(--platform-light);
        }
    </style>
</head>
<body>
    <h1 class="text-4xl font-bold my-4">Javelin Battle</h1>
    <div id="game-container">
        <canvas id="gameCanvas"></canvas>
    </div>
    <div id="controls-info">
        <div class="player-controls">
            <h2 class="font-bold mb-2">Player 1</h2>
            <p>Move: A / D (double-tap in air to dive)</p>
            <p>Jump: W</p>
            <p>Throw Spear: F</p>
            <p>Charge Cannon: Hold G</p>
            <p>Block: S</p>
        </div>
        <div class="player-controls text-right">
            <h2 class="font-bold mb-2">Player 2</h2>
            <p>Move: &larr; / &rarr; (double-tap in air to dive)</p>
            <p>Jump: &uarr;</p>
            <p>Throw Spear: , (Comma)</p>
            <p>Charge Cannon: Hold . (Period)</p>
            <p>Block: &darr;</p>
        </div>
    </div>
    <div id="gameOverScreen" class="hidden absolute inset-0 bg-black bg-opacity-75 flex-col justify-center items-center">
        <h2 id="winnerText" class="text-5xl font-bold mb-4"></h2>
        <button id="restartButton" class="px-8 py-4 bg-green-500 hover:bg-green-600 text-white font-bold rounded-lg shadow-lg transition-transform transform hover:scale-105">
            Play Again
        </button>
        <p class="mt-4 text-lg">or press SPACE to restart</p>
    </div>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const gameOverScreen = document.getElementById('gameOverScreen');
        const winnerText = document.getElementById('winnerText');
        const restartButton = document.getElementById('restartButton');
        const gameContainer = document.getElementById('game-container');

        let players, projectiles, keys, particles, gameFrame, platforms, windParticles, activeExplosions;
        let gravity = 0.35;
        let gameActive = true;
        let roundActive = true;
        let recentlyHitPlayerIndex = -1;

        let score = 0;
        const MAX_SCORE = 25;
        const DOUBLE_TAP_DELAY = 250;

        const C = {
            BG_DARK: '#0f380f',
            BG_MEDIUM: '#306230',
            PLATFORM: '#8bac0f',
            ACCENT: '#9bbc0f',
            WHITE: '#FFFFFF'
        };

        function resizeCanvas() {
            const containerRect = gameContainer.getBoundingClientRect();
            canvas.width = containerRect.width;
            canvas.height = containerRect.height;
            setupLevel();
            if (players) {
                init();
            }
        }
        
        function setupLevel() {
            const W = canvas.width;
            const H = canvas.height;
            platforms = [
                { x: 0, y: H - 20, width: W/2 - 50, height: 20, type: 'platform' },
                { x: W/2 + 50, y: H - 20, width: W/2 - 50, height: 20, type: 'platform' },
                { x: W/2 - 150, y: H - 80, width: 300, height: 60, type: 'platform' },
                { x: W/2 - 100, y: H - 140, width: 200, height: 60, type: 'platform' },
                { x: W/2 - 250, y: H - 200, width: 500, height: 60, type: 'platform' },
                { x: 50, y: H - 280, width: 100, height: 20, type: 'platform' },
                { x: W - 150, y: H - 280, width: 100, height: 20, type: 'platform' },
                { x: W/2 - 200, y: H - 280, width: 60, height: 20, type: 'platform' },
                { x: W/2 + 140, y: H - 280, width: 60, height: 20, type: 'platform' },
            ];
        }

        function setupWind() {
            windParticles = [];
            for(let i = 0; i < 30; i++) {
                windParticles.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    length: Math.random() * 20 + 10,
                    speed: Math.random() * 0.5 + 0.2
                });
            }
        }

        function init() {
            score = 0; gameActive = true; roundActive = true; recentlyHitPlayerIndex = -1;
            gameFrame = 0; gameOverScreen.classList.add('hidden'); gameOverScreen.classList.remove('flex');
            setupPlayers(); projectiles = []; particles = []; activeExplosions = []; keys = {};
            setupWind();
        }

        function setupPlayers() {
            const playerHeight = 35;
            const playerWidth = 20;
            
            players = [
                {
                    x: canvas.width/2 - 170, y: canvas.height - 280 - playerHeight, width: playerWidth, height: playerHeight,
                    color: C.WHITE, dx: 4.5, dy: 0, direction: 1, 
                    isMoving: false, isBlocking: false, onGround: true, jumpsLeft: 2,
                    jumpKey: 'w', throwKey: 'f', chargeKey: 'g', leftKey: 'a', rightKey: 'd', blockKey: 's',
                    isDashing: false, dashTimer: 0, dashRotation: 0, canDash: true, lastTap: {key: null, time: 0},
                    canThrow: true, throwCooldown: 0, throwCooldownTime: 45,
                    isCharging: false, chargePower: 0
                },
                {
                    x: canvas.width/2 + 150, y: canvas.height - 280 - playerHeight, width: playerWidth, height: playerHeight,
                    color: C.WHITE, dx: 4.5, dy: 0, direction: -1,
                    isMoving: false, isBlocking: false, onGround: true, jumpsLeft: 2,
                    jumpKey: 'arrowup', throwKey: ',', chargeKey: '.', leftKey: 'arrowleft', rightKey: 'arrowright', blockKey: 'arrowdown',
                    isDashing: false, dashTimer: 0, dashRotation: 0, canDash: true, lastTap: {key: null, time: 0},
                    canThrow: true, throwCooldown: 0, throwCooldownTime: 45,
                    isCharging: false, chargePower: 0
                }
            ];
        }

        function resetRound() {
            roundActive = true; recentlyHitPlayerIndex = -1; projectiles = []; keys = {};
            players.forEach((p, i) => {
                p.x = i === 0 ? canvas.width/2 - 170 : canvas.width/2 + 150;
                p.y = canvas.height - 280 - p.height;
                p.dy = 0; p.isMoving = false; p.isBlocking = false;
                p.onGround = true; p.jumpsLeft = 2; p.isDashing = false; p.canDash = true;
                p.canThrow = true; p.throwCooldown = 0; p.isCharging = false; p.chargePower = 0;
            });
        }

        function drawPlayer(player) {
            const { x, y, color, direction, isDashing, onGround, isBlocking, isMoving } = player;
            const h = player.height;
            const w = player.width;
            const headRadius = h / 6;
            const centerX = x + w / 2;
            
            ctx.fillStyle = color;
            ctx.strokeStyle = C.BG_DARK;
            ctx.lineWidth = 1.5;
            
            if (isDashing) {
                ctx.save();
                ctx.translate(centerX, y + h / 2);
                ctx.rotate(player.dashRotation);
                ctx.beginPath();
                ctx.arc(0, 0, w / 1.5, 0, Math.PI * 2);
                ctx.fill();
                ctx.stroke();
                ctx.restore();
            } else {
                const shieldWidth = 10;
                const shieldHeight = 25;
                
                if (isBlocking) {
                    ctx.save();
                    const shieldX = centerX + (direction * 15);
                    const shieldY = y + (h * 0.5);
                    ctx.fillStyle = C.PLATFORM;
                    ctx.strokeStyle = C.BG_DARK;
                    ctx.lineWidth = 2;
                    ctx.beginPath();
                    ctx.moveTo(shieldX - shieldWidth/2, shieldY - shieldHeight/2);
                    ctx.quadraticCurveTo(shieldX, shieldY - shieldHeight, shieldX + shieldWidth/2, shieldY - shieldHeight/2);
                    ctx.lineTo(shieldX + shieldWidth/2, shieldY + shieldHeight/2);
                    ctx.quadraticCurveTo(shieldX, shieldY + shieldHeight, shieldX - shieldWidth/2, shieldY + shieldHeight/2);
                    ctx.closePath();
                    ctx.fill();
                    ctx.stroke();
                    ctx.restore();
                }
                
                ctx.beginPath();
                ctx.arc(centerX, y + headRadius, headRadius, 0, Math.PI * 2);
                ctx.moveTo(centerX, y + headRadius * 2);
                ctx.lineTo(centerX, y + h * 0.7);
                
                if (!onGround) {
                    ctx.moveTo(centerX, y + h*0.4); ctx.lineTo(x, y + h*0.6);
                    ctx.moveTo(centerX, y + h*0.4); ctx.lineTo(x + w, y + h*0.6);
                    ctx.moveTo(centerX, y + h*0.7); ctx.lineTo(x + w*0.3, y + h - h*0.1);
                    ctx.moveTo(centerX, y + h*0.7); ctx.lineTo(x + w*0.7, y + h - h*0.1);
                } else {
                    ctx.moveTo(centerX, y + h*0.4); ctx.lineTo(x, y + h*0.6);
                    ctx.moveTo(centerX, y + h*0.4); ctx.lineTo(x + w, y + h*0.6);
                    ctx.moveTo(centerX, y + h*0.7); ctx.lineTo(x, y + h);
                    ctx.moveTo(centerX, y + h*0.7); ctx.lineTo(x + w, y + h);
                }
                ctx.fill();
                ctx.stroke();
            }

            if (!player.canThrow) {
                const cooldownRatio = player.throwCooldown / player.throwCooldownTime;
                const barWidth = w;
                const barHeight = 4;
                const barX = x;
                const barY = y - headRadius - 5;
                ctx.fillStyle = C.BG_DARK;
                ctx.fillRect(barX, barY, barWidth, barHeight);
                ctx.fillStyle = C.ACCENT;
                ctx.fillRect(barX, barY, barWidth * (1 - cooldownRatio), barHeight);
            } else if (player.isCharging) {
                 const chargeRatio = player.chargePower / 100;
                const barWidth = w;
                const barHeight = 4;
                const barX = x;
                const barY = y - headRadius - 5;
                ctx.fillStyle = C.BG_DARK;
                ctx.fillRect(barX, barY, barWidth, barHeight);
                ctx.fillStyle = '#ff0000'; // Red for cannon charge
                ctx.fillRect(barX, barY, barWidth * chargeRatio, barHeight);
            }
        }
        
        function drawPlatformPattern(p) {
             const brickHeight = 10;
             const brickWidth = 20;
             ctx.strokeStyle = C.BG_MEDIUM;
             ctx.lineWidth = 2;
             for (let y = p.y; y < p.y + p.height; y += brickHeight) {
                 for (let x = p.x; x < p.x + p.width; x += brickWidth) {
                     ctx.strokeRect(x, y, brickWidth, brickHeight);
                 }
             }
        }
        
        function drawLevel() {
            ctx.fillStyle = C.PLATFORM;
            platforms.forEach(p => {
                ctx.fillRect(p.x, p.y, p.width, p.height);
                drawPlatformPattern(p);
            });
        }
        
        function drawBackground() {
            const W = canvas.width;
            const H = canvas.height;
            ctx.fillStyle = C.PLATFORM;
            ctx.beginPath();
            ctx.arc(W * 0.15, H * 0.2, 50, 0, Math.PI * 2);
            ctx.fill();
            ctx.fillStyle = C.PLATFORM;
            ctx.beginPath();
            ctx.arc(W * 0.85, H * 0.2, 50, 0, Math.PI * 2);
            ctx.fill();
            ctx.fillStyle = C.BG_MEDIUM;
            ctx.beginPath();
            ctx.arc(W * 0.85 - 15, H * 0.2, 50, 0, Math.PI * 2);
            ctx.fill();
        }

        function drawWind() {
            ctx.strokeStyle = C.PLATFORM;
            ctx.lineWidth = 1;
            ctx.globalAlpha = 0.5;
            windParticles.forEach(p => {
                ctx.beginPath();
                ctx.moveTo(p.x, p.y);
                ctx.lineTo(p.x + p.length, p.y);
                ctx.stroke();
            });
            ctx.globalAlpha = 1.0;
        }

        function drawScoreBar() {
            const barY = 10; const barHeight = 20; const barWidth = canvas.width * 0.6;
            const barX = (canvas.width - barWidth) / 2; ctx.fillStyle = C.BG_DARK;
            ctx.fillRect(barX - 2, barY - 2, barWidth + 4, barHeight + 4); ctx.fillStyle = C.BG_MEDIUM;
            ctx.fillRect(barX, barY, barWidth, barHeight);
            ctx.fillStyle = C.ACCENT;
            const scoreWidth = (score / MAX_SCORE) * (barWidth / 2);
            ctx.fillRect(barX + barWidth/2, barY, scoreWidth, barHeight);
        }

        function drawProjectile(p) {
            ctx.fillStyle = C.WHITE;
            if (p.type === 'cannonball') {
                 ctx.fillStyle = C.BG_DARK;
                 ctx.beginPath();
                 ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                 ctx.fill();
            } else {
                ctx.save();
                ctx.translate(p.x + p.width / 2, p.y + p.height / 2);
                ctx.rotate(Math.atan2(p.dy, p.dx));
                ctx.fillRect(-p.width / 2, -p.height / 2, p.width, p.height);
                ctx.restore();
            }
        }

        function drawParticles() {
            particles.forEach(p => {
                ctx.globalAlpha = p.life / p.maxLife; ctx.fillStyle = p.color;
                ctx.beginPath(); ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2); ctx.fill();
            });
            ctx.globalAlpha = 1.0;
        }

        function drawExplosions() {
             for (let i = activeExplosions.length - 1; i >= 0; i--) {
                const exp = activeExplosions[i];
                ctx.globalAlpha = (exp.life / exp.maxLife) * 0.8;
                ctx.strokeStyle = C.WHITE;
                ctx.lineWidth = 4;
                ctx.beginPath();
                ctx.arc(exp.x, exp.y, exp.currentRadius, 0, Math.PI * 2);
                ctx.stroke();
            }
            ctx.globalAlpha = 1.0;
        }

        function draw() {
            ctx.fillStyle = C.BG_MEDIUM;
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            drawBackground();
            drawWind();
            drawLevel();
            if (recentlyHitPlayerIndex !== 0) drawPlayer(players[0]);
            if (recentlyHitPlayerIndex !== 1) drawPlayer(players[1]);
            projectiles.forEach(drawProjectile);
            drawParticles();
            drawExplosions();
            drawScoreBar();
        }

        function createPlayerDeathExplosion(x, y) { for (let i = 0; i < 30; i++) particles.push({ x, y, dx: (Math.random() - 0.5) * 8, dy: (Math.random() - 0.7) * 10, radius: Math.random() * 3 + 1, color: C.WHITE, life: 60, maxLife: 60 }); }
        function createJumpParticles(x, y) { for (let i = 0; i < 15; i++) particles.push({ x, y, dx: (Math.random() - 0.5) * 4, dy: Math.random() * 2 + 1, radius: Math.random() * 2 + 1, color: C.WHITE, life: 30, maxLife: 30 }); }
        function createDashParticles(x, y, color) { for (let i = 0; i < 5; i++) particles.push({ x, y, dx: (Math.random() - 0.5) * 2, dy: (Math.random() - 0.5) * 2, radius: Math.random() * 2, color: C.WHITE, life: 20, maxLife: 20 }); }
        
        function updateParticles() { for (let i = particles.length - 1; i >= 0; i--) { const p = particles[i]; p.dy += gravity * 0.1; p.x += p.dx; p.y += p.dy; p.life--; if (p.life <= 0) particles.splice(i, 1); } }
        function updateWind() {
            windParticles.forEach(p => {
                p.x -= p.speed;
                if (p.x + p.length < 0) {
                    p.x = canvas.width;
                    p.y = Math.random() * canvas.height;
                }
            });
        }
        function updateExplosions() {
             for (let i = activeExplosions.length - 1; i >= 0; i--) {
                const exp = activeExplosions[i];
                exp.life--;
                exp.currentRadius = exp.maxRadius * (1 - (exp.life / exp.maxLife));
                if (exp.life <= 0) {
                    activeExplosions.splice(i, 1);
                }
            }
        }
        
        function updatePlayer(player) {
            if (player.isDashing) {
                player.y += player.dy; player.dy += gravity * 0.5; player.x += player.dxDash;
                player.dashRotation += player.direction * 0.4; player.dashTimer--;
                createDashParticles(player.x + (player.width / 2), player.y + (player.height / 2));
                if (player.dashTimer <= 0) { player.isDashing = false; }
                platforms.forEach(p => { if (player.y + player.height > p.y && player.y < p.y + p.height && player.x + player.width > p.x && player.x < p.x + p.width) { player.isDashing = false; } });
                return;
            }

            if (!player.canThrow) {
                player.throwCooldown--;
                if(player.throwCooldown <= 0) {
                    player.canThrow = true;
                }
            }

            player.isBlocking = keys[player.blockKey] || false;
            
            player.isCharging = keys[player.chargeKey] && !player.isBlocking;
             if (player.isCharging) {
                if(player.chargePower < 100) player.chargePower += 1.5;
            }

            player.isMoving = false;
            const currentDx = player.dx;
            if (!player.isBlocking && !player.isCharging) {
                if (keys[player.leftKey]) { player.x -= currentDx; player.isMoving = true; }
                if (keys[player.rightKey]) { player.x += currentDx; player.isMoving = true; }
            }
            if (keys[player.leftKey] && !keys[player.rightKey]) player.direction = -1;
            if (keys[player.rightKey] && !keys[player.leftKey]) player.direction = 1;
            
            const prevY = player.y;
            player.dy += gravity;
            player.y += player.dy;
            player.onGround = false;
            
            platforms.forEach(p => {
                if (player.x < p.x + p.width && player.x + player.width > p.x && player.y < p.y + p.height && player.y + player.height > p.y) {
                    if (player.dy >= 0 && (prevY + player.height) <= p.y + 1) {
                        player.y = p.y - player.height; player.dy = 0; player.onGround = true;
                        player.jumpsLeft = 2; player.canDash = true;
                    } else if (player.dy < 0 && prevY >= (p.y + p.height)) {
                         player.y = p.y + p.height; player.dy = 0;
                    }
                }
            });

            if (player.x + player.width < 0) { player.x = canvas.width; } 
            else if (player.x > canvas.width) { player.x = -player.width; }
            
            if (player.y > canvas.height) {
                const playerIndex = players.indexOf(player); const opponentIndex = playerIndex === 0 ? 1 : 0;
                roundActive = false; recentlyHitPlayerIndex = playerIndex; createPlayerDeathExplosion(player.x, canvas.height);
                score += (opponentIndex === 0 ? 5 : -5);
                if (Math.abs(score) >= MAX_SCORE) { endGame(opponentIndex); } else { setTimeout(resetRound, 1000); }
            }
        }

        function handleCannonballImpact(cannonball) {
            activeExplosions.push({ x: cannonball.x, y: cannonball.y, currentRadius: 0, maxRadius: cannonball.blastRadius, life: 20, maxLife: 20 });
            for (let i = 0; i < 40; i++) particles.push({ x: cannonball.x, y: cannonball.y, dx: (Math.random() - 0.5) * 12, dy: (Math.random() - 0.5) * 12, radius: Math.random() * 2 + 1, color: C.WHITE, life: 20, maxLife: 20 });
            
            if (roundActive) {
                let wasHit = false;
                players.forEach((player, playerIndex) => {
                    if (cannonball.owner === playerIndex || player.isDashing) return;
                    const distance = Math.hypot(cannonball.x - (player.x + player.width/2), cannonball.y - (player.y + player.height/2));
                    if (distance < cannonball.blastRadius) {
                        wasHit = true;
                        recentlyHitPlayerIndex = playerIndex;
                    }
                });

                if (wasHit) {
                    roundActive = false; 
                    score += (cannonball.owner === 0 ? 5 : -5); 
                    if (Math.abs(score) >= MAX_SCORE) { 
                        endGame(cannonball.owner); 
                    } else { 
                        setTimeout(resetRound, 1000); 
                    }
                }
            }
        }
        
        function updateProjectiles() {
            for (let pIndex = projectiles.length - 1; pIndex >= 0; pIndex--) {
                const p = projectiles[pIndex];
                p.dy += gravity * (p.type === 'cannonball' ? 0.7 : 1); 
                p.x += p.dx; p.y += p.dy;
                
                if (p.x + (p.width||p.radius*2) < 0) { p.x = canvas.width; } else if (p.x > canvas.width) { p.x = -(p.width||p.radius*2); }

                let hitSomething = false;
                for(const plat of platforms) { if (p.x < plat.x + plat.width && p.x + (p.width || p.radius*2) > plat.x && p.y < plat.y + plat.height && p.y + (p.height || p.radius*2) > plat.y) {
                    hitSomething = true;
                    if(p.type === 'cannonball') {
                        handleCannonballImpact(p);
                    }
                    projectiles.splice(pIndex, 1); 
                    break;
                }}
                if(hitSomething) continue;

                for (let playerIndex = 0; playerIndex < players.length; playerIndex++) {
                    const player = players[playerIndex];
                    if (p.owner === playerIndex || player.isDashing) continue; 
                    
                    let directHit = false; 
                    if (p.type === 'cannonball') {
                         directHit = Math.hypot(p.x - (player.x + player.width/2), p.y - (player.y + player.height/2)) < p.radius + player.width/2;
                    } else {
                         directHit = p.x < player.x + player.width && p.x + p.width > player.x && p.y < player.y + player.height && p.y + p.height > player.y;
                    }
                    
                    if (player.isBlocking && p.type === 'spear') { 
                        const shieldW = 8, shieldH = 25, angle = 45 * Math.PI / 180; const boxW = shieldW * Math.cos(angle) + shieldH * Math.sin(angle); const boxH = shieldW * Math.sin(angle) + shieldH * Math.cos(angle); const shieldCenterX = player.x + player.width / 2 + player.direction * 15; const shieldCenterY = player.y + player.height * 0.4; const boxX = shieldCenterX - boxW / 2; const boxY = shieldCenterY - boxH / 2; 
                        if (p.x < boxX + boxW && p.x + p.width > boxX && p.y < boxY + boxH && p.y + p.height > boxY) { 
                            projectiles.splice(pIndex, 1); hitSomething = true; break; 
                        } 
                    } 
                    if (directHit) {
                         if(p.type === 'cannonball') {
                            handleCannonballImpact(p);
                         } else {
                            roundActive = false; recentlyHitPlayerIndex = playerIndex; createPlayerDeathExplosion(player.x + player.width / 2, player.y + player.height / 2); score += (p.owner === 0 ? 5 : -5); if (Math.abs(score) >= MAX_SCORE) { endGame(p.owner); } else { setTimeout(resetRound, 1000); } 
                         }
                        projectiles.splice(pIndex, 1);
                        hitSomething = true;
                        break;
                    }
                }
                 if(hitSomething) continue;
            }
        }
        
        function endGame(winnerIndex) {
            gameActive = false;
            winnerText.textContent = `Player ${winnerIndex + 1} Wins!`;
            winnerText.style.color = C.ACCENT;
            gameOverScreen.classList.remove('hidden');
            gameOverScreen.classList.add('flex');
        }

        function gameLoop() {
            if (!gameActive) return;
            gameFrame++;
            if (roundActive) {
                updatePlayer(players[0]);
                updatePlayer(players[1]);
                updateProjectiles();
            }
            updateWind();
            updateParticles();
            updateExplosions();
            draw();
            requestAnimationFrame(gameLoop);
        }

        window.addEventListener('keydown', (e) => {
            const key = e.key.toLowerCase(); if (!roundActive || keys[key]) return; keys[key] = true;
            players.forEach((player, index) => {
                if (key === player.leftKey || key === player.rightKey) { const now = performance.now(); if (!player.onGround && player.canDash && (now - player.lastTap.time < DOUBLE_TAP_DELAY) && key === player.lastTap.key) { player.isDashing = true; player.dashTimer = 25; player.dxDash = 8 * player.direction; player.dy = 2; player.canDash = false; player.jumpsLeft = 0; } player.lastTap = { key: key, time: now }; }
                if (key === player.jumpKey && player.jumpsLeft > 0 && !player.isDashing) { player.dy = -11; player.jumpsLeft--; player.onGround = false; if (player.jumpsLeft === 0) { createJumpParticles(player.x + (player.width / 2), player.y + player.height); } }
                if (key === player.throwKey && player.canThrow && !player.isBlocking && !player.isDashing) {
                    player.canThrow = false;
                    player.throwCooldown = player.throwCooldownTime;
                    let numSpears = 1; if (index === 0 && score < 0) { numSpears = 1 + Math.floor(Math.abs(score) / 5); } else if (index === 1 && score > 0) { numSpears = 1 + Math.floor(score / 5); } const angleSpread = numSpears > 1 ? 0.3 : 0; for(let i = 0; i < numSpears; i++) { const baseAngle = player.onGround ? Math.PI / 4 : 0.1; const newAngle = baseAngle - (angleSpread/2) + (i / Math.max(1, numSpears-1)) * angleSpread; const initialVelocity = 11; projectiles.push({ type: 'spear', x: player.x + (player.width / 2), y: player.y + (player.height)*0.4, width: 30, height: 2, dx: initialVelocity * Math.cos(newAngle) * player.direction, dy: -initialVelocity * Math.sin(newAngle), owner: index }); } 
                }
            });
        });
        
        window.addEventListener('keyup', (e) => { 
            const key = e.key.toLowerCase(); 
            if (keys[key]) keys[key] = false;

            players.forEach((player, index) => {
                 if (key === player.chargeKey && player.isCharging) {
                     player.isCharging = false;
                     if(player.canThrow) {
                        player.canThrow = false;
                        player.throwCooldown = player.throwCooldownTime * 3; // Longer cooldown for cannon
                        const initialVelocity = 4 + (player.chargePower / 100) * 8;
                        projectiles.push({
                            type: 'cannonball',
                            x: player.x + player.width/2,
                            y: player.y + player.height/2,
                            radius: 8,
                            blastRadius: 60,
                            dx: initialVelocity * Math.cos(Math.PI/4) * player.direction,
                            dy: -initialVelocity * Math.sin(Math.PI/4),
                            owner: index
                        });
                        player.chargePower = 0;
                     }
                 }
            });

            if (!gameActive && key === ' ') { init(); gameLoop(); } 
        });
        
        restartButton.addEventListener('click', () => { init(); gameLoop(); });
        window.addEventListener('resize', resizeCanvas);

        resizeCanvas();
        init();
        gameLoop();
    </script>
</body>
</html>
